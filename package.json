{
  "name": "mailforge",
  "version": "1.0.0",
  "private": true,
  "description": "Self-hosted email delivery, contact management, warmup and deliverability monitoring platform",
  "license": "MIT",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:migrate": "pnpm --filter @mailforge/api prisma migrate dev",
    "db:generate": "pnpm --filter @mailforge/api prisma generate",
    "db:seed": "pnpm --filter @mailforge/api prisma db seed",
    "db:studio": "pnpm --filter @mailforge/api prisma studio"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
