# ============================================================
# MailForge Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Application
NODE_ENV=development
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
PORT=3001

# Database (MySQL/MariaDB)
DATABASE_URL=mysql://mailforge:secret@localhost:3306/mailforge

# Redis
REDIS_URL=redis://localhost:6379

# JWT Authentication
# Generate with: openssl rand -base64 32
JWT_SECRET=change-me-in-production-use-32-chars-min
JWT_REFRESH_SECRET=change-me-refresh-use-different-32-chars
JWT_ACCESS_TTL=900        # 15 minutes in seconds
JWT_REFRESH_TTL=604800    # 7 days in seconds

# Encryption key for SMTP passwords (AES-256-GCM)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=change-me-encryption-key-exactly-32c

# File uploads
UPLOAD_DIR=./uploads
MAX_IMPORT_FILE_SIZE_MB=50

# MinIO (S3-compatible storage) — optional for file storage
# MINIO_ENDPOINT=localhost
# MINIO_PORT=9000
# MINIO_USE_SSL=false
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=mailforge

# Bull Board (queue monitoring UI)
BULL_BOARD_USERNAME=admin
BULL_BOARD_PASSWORD=change-me

# Optional: External email for system notifications
# SYSTEM_EMAIL_HOST=smtp.gmail.com
# SYSTEM_EMAIL_PORT=587
# SYSTEM_EMAIL_USER=your@email.com
# SYSTEM_EMAIL_PASS=your-app-password
# SYSTEM_EMAIL_FROM=MailForge <noreply@yourdomain.com>
